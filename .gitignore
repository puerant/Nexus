# ============================================================
# Tauri + Rust Project .gitignore
# ============================================================

# ============================================================
# Rust
# ============================================================
target/
**/*.rs.bk
*.pdb
Cargo.lock

# ============================================================
# Tauri
# ============================================================
src-tauri/target/
src-tauri/WixTools/
*.app
*.dmg
*.deb
*.AppImage
*.msi
*.exe
*.rpm

# Tauri generated files
src-tauri/gen/
!src-tauri/gen/schemas/

# ============================================================
# Node.js / Frontend
# ============================================================
node_modules/
dist/
dist-ssr/
build/
.output/
.nuxt/
.next/

# Package manager locks (keep only one, comment out what you don't use)
# package-lock.json
# yarn.lock
# bun.lockb
# pnpm-lock.yaml

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.local
.env.*.local
.env.production
*.secret
secrets/

# ============================================================
# IDE & Editors
# ============================================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (RustRover, CLion, etc.)
.idea/
*.iml
*.iws
*.ipr

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates

# Vim / Neovim
*.swp
*.swo
*~
.vim/

# Emacs
\#*\#
.\#*

# ============================================================
# OS Generated Files
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ============================================================
# Logs & Debug
# ============================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
crash-reports/

# ============================================================
# Testing & Coverage
# ============================================================
coverage/
*.lcov
.nyc_output/

# ============================================================
# Misc
# ============================================================
*.tmp
*.temp
*.bak
*.orig
.cache/
.parcel-cache/
.turbo/
